# Zola output directory
/public

# Zola binary and man pages downloaded for local builds
/zola
/artifacts/

# Zola cache files
/.zola_cache

# Zola config and content temporary files
# Used by some editors/IDEs, e.g. Emacs
*.zw*
*.tmp

# IDEs and OS generated files
.DS_Store
.vscode/
.idea/

# Dotenv files
.env
.env.*

# Source ebooks / reference PDFs (not part of the built site)
/*.pdf

# Add theme if it's a git submodule
# /themes/your_theme_name
